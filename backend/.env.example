# backend/.env.example
# Copy this file to .env and fill in all values before running the server.
# Never commit .env to git.

# ── Database (Supabase) ──────────────────────────────────────────
# From: Supabase Dashboard → Settings → Database → Connection strings

# Transaction pooler (port 6543) — used by the running app
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres"

# Direct connection (port 5432) — used by Prisma CLI for migrations ONLY
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ── App ─────────────────────────────────────────────────────────
PORT=3000
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000

# ── JWT ─────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️ REQUIRED — server will crash on startup if not set
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING_64_HEX_CHARS

# ── Google OAuth ─────────────────────────────────────────────────
# From: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
# Redirect URI to register: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET
